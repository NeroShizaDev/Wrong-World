{
  "name": "wrong-world",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "android:install": "npm install @capacitor/core @capacitor/cli @capacitor/android --save",
    "android:init": "npm run build && npx --no-install cap add android",
    "android:sync": "npm run build && npx --no-install cap sync android",
    "android:open": "npx --no-install cap open android",
    "android:build": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:doctor": "node scripts/android-doctor.mjs"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  }
}
